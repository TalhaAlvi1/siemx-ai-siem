# SIEMX Inventory File
# Define your hosts and groups here

[siem_servers]
# Production SIEM server
siem-server ansible_host=192.168.1.100 ansible_user=ubuntu

# Local development (uncomment for local testing)
# localhost ansible_connection=local

[log_sources]
# Windows servers
win-server1 ansible_host=192.168.1.101 ansible_user=Administrator ansible_connection=winrm ansible_winrm_server_cert_validation=ignore
win-server2 ansible_host=192.168.1.102 ansible_user=Administrator ansible_connection=winrm ansible_winrm_server_cert_validation=ignore

# Linux servers
linux-server1 ansible_host=192.168.1.103 ansible_user=ubuntu
linux-server2 ansible_host=192.168.1.104 ansible_user=ubuntu

[network_devices]
# Network equipment
router1 ansible_host=192.168.1.1
firewall1 ansible_host=192.168.1.2

[all:vars]
# Global variables for all hosts
ansible_python_interpreter=/usr/bin/python3